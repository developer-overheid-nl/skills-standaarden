{
  "release-type": "simple",
  "bump-minor-pre-major": true,
  "changelog-path": "CHANGELOG.md",
  "packages": {
    ".": {
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        },
        {
          "type": "yaml",
          "path": "publiccode.yml",
          "jsonpath": "$.softwareVersion"
        }
      ]
    }
  }
}
